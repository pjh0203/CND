#!/usr/bin/env python
# Custom New York Times recipe for CND.
# RSS-based (not full-site scrape). NYT meters via front-end JS, so the
# article HTML usually still contains the body and auto_cleanup can extract
# it. Some articles may come through truncated when the paywall is server-side.
from calibre.web.feeds.news import BasicNewsRecipe


class NytCustom(BasicNewsRecipe):
    title = 'The New York Times (Custom)'
    __author__ = 'Harry'
    description = ('Curated New York Times: world, US, politics, business, '
                   'tech, science and opinion. Built from RSS.')
    language = 'en_US'
    publication_type = 'newspaper'
    oldest_article = 1            # newspaper: today's news only
    max_articles_per_feed = 18    # cap per section (lower this if file too big)
    no_stylesheets = True
    remove_javascript = True
    auto_cleanup = True           # generic full-text extraction; robust to site changes
    ignore_duplicate_articles = {'title', 'url'}
    remove_empty_feeds = True

    # Keep the EPUB under the 25 MB email limit: shrink + compress images.
    compress_news_images = True
    compress_news_images_max_size = 12   # KB per image
    scale_news_images = (600, 700)       # max width x height in px

    feeds = [
        ('World', 'https://rss.nytimes.com/services/xml/rss/nyt/World.xml'),
        ('US', 'https://rss.nytimes.com/services/xml/rss/nyt/US.xml'),
        ('Politics', 'https://rss.nytimes.com/services/xml/rss/nyt/Politics.xml'),
        ('Business', 'https://rss.nytimes.com/services/xml/rss/nyt/Business.xml'),
        ('Technology', 'https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml'),
        ('Science', 'https://rss.nytimes.com/services/xml/rss/nyt/Science.xml'),
        ('Opinion', 'https://rss.nytimes.com/services/xml/rss/nyt/Opinion.xml'),
    ]
