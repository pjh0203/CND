#!/usr/bin/env python
# Custom Economist recipe for CND.
# RSS-based. NOTE: The Economist is a hard, server-side paywall. Without a
# subscription, auto_cleanup will usually only recover the headline plus the
# opening paragraph(s) for most articles. The "world this week" and "leaders"
# sections carry the most self-contained, readable content for free, so they
# are listed first. If you have a subscription you can add cookie-based login
# later; for now this is a best-effort free digest.
from calibre.web.feeds.news import BasicNewsRecipe


class EconomistCustom(BasicNewsRecipe):
    title = 'The Economist (Custom)'
    __author__ = 'Harry'
    description = ('Best-effort free Economist digest built from section RSS. '
                   'Most full text is paywalled; expect headlines + summaries.')
    language = 'en_GB'
    publication_type = 'magazine'
    oldest_article = 8            # weekly magazine: roughly one issue
    max_articles_per_feed = 12
    no_stylesheets = True
    remove_javascript = True
    auto_cleanup = True
    ignore_duplicate_articles = {'title', 'url'}
    remove_empty_feeds = True

    compress_news_images = True
    compress_news_images_max_size = 12
    scale_news_images = (600, 700)

    feeds = [
        ('The world this week', 'https://www.economist.com/the-world-this-week/rss.xml'),
        ('Leaders', 'https://www.economist.com/leaders/rss.xml'),
        ('Briefing', 'https://www.economist.com/briefing/rss.xml'),
        ('United States', 'https://www.economist.com/united-states/rss.xml'),
        ('China', 'https://www.economist.com/china/rss.xml'),
        ('Europe', 'https://www.economist.com/europe/rss.xml'),
        ('Business', 'https://www.economist.com/business/rss.xml'),
        ('Finance & economics', 'https://www.economist.com/finance-and-economics/rss.xml'),
        ('Science & technology', 'https://www.economist.com/science-and-technology/rss.xml'),
    ]
