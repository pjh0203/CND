#!/usr/bin/env python
# Custom Guardian recipe for CND.
# RSS-based (not full-site scrape), so it stays small and survives redesigns.
from calibre.web.feeds.news import BasicNewsRecipe


class GuardianCustom(BasicNewsRecipe):
    title = 'The Guardian (Custom)'
    __author__ = 'Harry'
    description = ('Curated Guardian: world, politics, business, tech, opinion, '
                   'plus rich football and culture coverage. Built from RSS.')
    language = 'en_GB'
    publication_type = 'newspaper'
    oldest_article = 2            # only the last 2 days
    max_articles_per_feed = 18    # cap per section (lower this if file too big)
    no_stylesheets = True
    remove_javascript = True
    auto_cleanup = True           # generic full-text extraction; robust to site changes
    ignore_duplicate_articles = {'title', 'url'}
    remove_empty_feeds = True

    # Keep the EPUB under the 25 MB email limit: shrink + compress images.
    compress_news_images = True
    compress_news_images_max_size = 12   # KB per image
    scale_news_images = (600, 700)       # max width x height in px

    feeds = [
        # --- News & analysis ---
        ('World', 'https://www.theguardian.com/world/rss'),
        ('Europe', 'https://www.theguardian.com/world/europe-news/rss'),
        ('US news', 'https://www.theguardian.com/us-news/rss'),
        ('UK politics', 'https://www.theguardian.com/politics/rss'),
        ('Business', 'https://www.theguardian.com/business/rss'),
        ('Economics', 'https://www.theguardian.com/business/economics/rss'),
        ('Technology', 'https://www.theguardian.com/technology/rss'),
        ('Environment', 'https://www.theguardian.com/environment/rss'),
        ('Science', 'https://www.theguardian.com/science/rss'),
        ('Opinion', 'https://www.theguardian.com/commentisfree/rss'),
        # --- Football (kept rich) ---
        ('Football', 'https://www.theguardian.com/football/rss'),
        # --- Culture (kept rich) ---
        ('Culture', 'https://www.theguardian.com/culture/rss'),
        ('Film', 'https://www.theguardian.com/film/rss'),
        ('Music', 'https://www.theguardian.com/music/rss'),
        ('Books', 'https://www.theguardian.com/books/rss'),
        ('Art & design', 'https://www.theguardian.com/artanddesign/rss'),
        ('TV & radio', 'https://www.theguardian.com/tv-and-radio/rss'),
        ('Games', 'https://www.theguardian.com/games/rss'),
    ]

    # Skip Guardian live blogs / rolling coverage. These are single giant
    # DOM pages that calibre cannot split, and they crash the whole EPUB
    # (SplitError: "Could not find reasonable point at which to split").
    def is_live_blog(self, article):
        url = (article.url or '').lower()
        title = (article.title or '').lower()
        if '/live/' in url:
            return True
        live_markers = (
            '– live',          # en-dash variant (Guardian's default)
            '- live',          # hyphen variant
            'live –',
            'live -',
            'as it happened',
            'as it happens',
        )
        return any(marker in title for marker in live_markers)

    def parse_feeds(self):
        feeds = super().parse_feeds()
        for feed in feeds:
            for article in list(feed.articles):
                if self.is_live_blog(article):
                    self.log('Skipping live blog:', article.title)
                    feed.articles.remove(article)
        return feeds
